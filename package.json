{
  "name": "bakugekikun",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "postbuild": "node -e \"const fs=require('fs');fs.copyFileSync('dist/index.html','bakugekikun.html');fs.mkdirSync('docs',{recursive:true});fs.copyFileSync('dist/index.html','docs/index.html')\"",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "three": "^0.185.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/three": "^0.185.0",
    "typescript": "7.0.1-rc",
    "vite": "^8.1.3",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^4.1.10"
  }
}
